# wcdiag runtime output — never commit captures or logs (they contain your
# public IP, device MACs, and other identifying network data)
*.pcap
*.pcapng
*.csv
*.log
wcdiag-capture/
wcdiag-doctor.csv
wcdiag-monitor.csv

# committed test fixtures are the exception to the *.log rule above
!tests/fixtures/
!tests/fixtures/*.log

# editors / os
*.swp
.DS_Store
